# Copy this file to .env.local for local dev, or set these in Vercel project settings.

# Gemini - use rotation keys (recommended) OR a single key.
GEMINI_API_KEY_1=your-gemini-key-1
GEMINI_API_KEY_2=your-gemini-key-2
# ... up to GEMINI_API_KEY_8
# GEMINI_API_KEY=your-single-gemini-key

# Pinecone
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=dc-sentinel
